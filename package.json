{
  "name": "taxi4drive",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev -w @taxi4drive/web",
    "dev:api": "npm run dev -w @taxi4drive/api",
    "build": "npm run build -w @taxi4drive/web",
    "start": "concurrently \"npm run start -w @taxi4drive/web\" \"npm run start -w @taxi4drive/api\"",
    "lint": "npm run lint -w @taxi4drive/web",
    "backup": "npm run backup -w @taxi4drive/api",
    "mobile": "npm run start -w @taxi4drive/mobile"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
