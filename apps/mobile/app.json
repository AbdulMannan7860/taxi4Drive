{
  "expo": {
    "name": "Taxi2Airport Admin",
    "slug": "taxi2airport-admin",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.taxi2airport.admin",
      "adaptiveIcon": {
        "backgroundColor": "#0b1d33",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0b1d33",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "aa66a2f8-435f-4e9c-a050-82979e702627"
      }
    },
    "owner": "abdul_5110",
    "updates": {
      "url": "https://u.expo.dev/aa66a2f8-435f-4e9c-a050-82979e702627"
    }
  }
}
