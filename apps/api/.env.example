MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/
# Optional: override DNS when mongodb+srv SRV lookups fail (router/VPN DNS issues)
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_DB=data4drive
MONGODB_COLLECTION=bookings
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
JWT_SECRET=change-this-secret-before-production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
BOOKING_RATE_LIMIT_WINDOW_MS=600000
BOOKING_RATE_LIMIT_MAX=10
BACKUP_DIR=backups
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Taxi4Drive <book@taxi4drive.com.au>
